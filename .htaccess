# =============================================
# .htaccess - Configuración de seguridad
# Torneo de Fútbol – Montería, Córdoba
# =============================================

# --- Bloquear acceso a archivos sensibles ---
<FilesMatch "\.(sql|md|git|env|json|log)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# --- Deshabilitar listado de directorios ---
Options -Indexes

# --- Cabeceras de seguridad ---
<IfModule mod_headers.c>

    # Content-Security-Policy (mantener alineada con vercel.json → headers Content-Security-Policy)
    # script-src sin 'unsafe-inline'; style-src con 'unsafe-inline' por plantillas dinámicas (dashboard / panel).
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: blob: https://*.supabase.co; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.emailjs.com; object-src 'none'; worker-src 'none'; media-src 'none'; form-action 'self'; base-uri 'self'; frame-ancestors 'none';"

    # Evita que el navegador adivine el MIME type
    Header set X-Content-Type-Options "nosniff"

    # Evita clickjacking (redundante con frame-ancestors 'none' pero añade compatibilidad)
    Header set X-Frame-Options "DENY"

    # Fuerza HTTPS en el navegador durante 1 año (activar cuando tengas SSL)
    # Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Política de referrer: solo origen, sin ruta
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Deshabilitar características del navegador innecesarias
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"

</IfModule>

# --- Redirigir a HTTPS (activar cuando tengas SSL) ---
# <IfModule mod_rewrite.c>
#     RewriteEngine On
#     RewriteCond %{HTTPS} off
#     RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>

# --- Caracteres UTF-8 por defecto ---
AddDefaultCharset UTF-8
